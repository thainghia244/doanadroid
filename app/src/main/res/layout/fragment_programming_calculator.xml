<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/white">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="16dp">

        <RadioGroup
            android:id="@+id/rg_equation_type"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginBottom="16dp">

            <RadioButton
                android:id="@+id/rb_quadratic"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="Bậc 2"
                android:checked="true" />

            <RadioButton
                android:id="@+id/rb_cubic"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="Bậc 3" />

            <RadioButton
                android:id="@+id/rb_system_2x2"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="Hệ 2x2" />

            <RadioButton
                android:id="@+id/rb_system_3x3"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="Hệ 3x3" />
        </RadioGroup>

        <LinearLayout
            android:id="@+id/container_quadratic"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:visibility="visible">

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Phương trình: ax² + bx + c = 0"
                android:textSize="16sp"
                android:textStyle="bold"
                android:layout_marginBottom="8dp" />

            <EditText
                android:id="@+id/et_quad_a"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:hint="Nhập a"
                android:inputType="numberDecimal|numberSigned"
                android:layout_marginBottom="8dp" />

            <EditText
                android:id="@+id/et_quad_b"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:hint="Nhập b"
                android:inputType="numberDecimal|numberSigned"
                android:layout_marginBottom="8dp" />

            <EditText
                android:id="@+id/et_quad_c"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:hint="Nhập c"
                android:inputType="numberDecimal|numberSigned"
                android:layout_marginBottom="8dp" />

            <Button
                android:id="@+id/btn_solve_quad"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Giải"
                android:backgroundTint="@color/teal_700" />

        </LinearLayout>

        <LinearLayout
            android:id="@+id/container_cubic"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:visibility="gone">

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Phương trình: ax³ + bx² + cx + d = 0"
                android:textSize="16sp"
                android:textStyle="bold"
                android:layout_marginBottom="8dp" />

            <EditText
                android:id="@+id/et_cub_a"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:hint="Nhập a"
                android:inputType="numberDecimal|numberSigned"
                android:layout_marginBottom="8dp" />

            <EditText
                android:id="@+id/et_cub_b"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:hint="Nhập b"
                android:inputType="numberDecimal|numberSigned"
                android:layout_marginBottom="8dp" />

            <EditText
                android:id="@+id/et_cub_c"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:hint="Nhập c"
                android:inputType="numberDecimal|numberSigned"
                android:layout_marginBottom="8dp" />

            <EditText
                android:id="@+id/et_cub_d"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:hint="Nhập d"
                android:inputType="numberDecimal|numberSigned"
                android:layout_marginBottom="8dp" />

            <Button
                android:id="@+id/btn_solve_cub"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Giải"
                android:backgroundTint="@color/teal_700" />

        </LinearLayout>

        <LinearLayout
            android:id="@+id/container_system_2x2"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:visibility="gone">

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="a₁x + b₁y = c₁"
                android:textSize="14sp"
                android:layout_marginBottom="8dp" />

            <EditText
                android:id="@+id/et_sys2x2_a1"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:hint="a₁"
                android:inputType="numberDecimal|numberSigned"
                android:layout_marginBottom="4dp" />

            <EditText
                android:id="@+id/et_sys2x2_b1"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:hint="b₁"
                android:inputType="numberDecimal|numberSigned"
                android:layout_marginBottom="4dp" />

            <EditText
                android:id="@+id/et_sys2x2_c1"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:hint="c₁"
                android:inputType="numberDecimal|numberSigned"
                android:layout_marginBottom="8dp" />

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="a₂x + b₂y = c₂"
                android:textSize="14sp"
                android:layout_marginBottom="8dp" />

            <EditText
                android:id="@+id/et_sys2x2_a2"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:hint="a₂"
                android:inputType="numberDecimal|numberSigned"
                android:layout_marginBottom="4dp" />

            <EditText
                android:id="@+id/et_sys2x2_b2"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:hint="b₂"
                android:inputType="numberDecimal|numberSigned"
                android:layout_marginBottom="4dp" />

            <EditText
                android:id="@+id/et_sys2x2_c2"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:hint="c₂"
                android:inputType="numberDecimal|numberSigned"
                android:layout_marginBottom="8dp" />

            <Button
                android:id="@+id/btn_solve_sys_2x2"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Giải"
                android:backgroundTint="@color/teal_700" />

        </LinearLayout>

        <LinearLayout
            android:id="@+id/container_system_3x3"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:visibility="gone">

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="a₁x + b₁y + c₁z = d₁"
                android:textSize="12sp"
                android:layout_marginBottom="2dp" />

            <EditText
                android:id="@+id/et_sys3x3_a1"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:hint="a₁"
                android:inputType="numberDecimal|numberSigned"
                android:layout_marginBottom="2dp" />

            <EditText
                android:id="@+id/et_sys3x3_b1"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:hint="b₁"
                android:inputType="numberDecimal|numberSigned"
                android:layout_marginBottom="2dp" />

            <EditText
                android:id="@+id/et_sys3x3_c1"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:hint="c₁"
                android:inputType="numberDecimal|numberSigned"
                android:layout_marginBottom="2dp" />

            <EditText
                android:id="@+id/et_sys3x3_d1"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:hint="d₁"
                android:inputType="numberDecimal|numberSigned"
                android:layout_marginBottom="8dp" />

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="a₂x + b₂y + c₂z = d₂"
                android:textSize="12sp"
                android:layout_marginBottom="2dp" />

            <EditText
                android:id="@+id/et_sys3x3_a2"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:hint="a₂"
                android:inputType="numberDecimal|numberSigned"
                android:layout_marginBottom="2dp" />

            <EditText
                android:id="@+id/et_sys3x3_b2"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:hint="b₂"
                android:inputType="numberDecimal|numberSigned"
                android:layout_marginBottom="2dp" />

            <EditText
                android:id="@+id/et_sys3x3_c2"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:hint="c₂"
                android:inputType="numberDecimal|numberSigned"
                android:layout_marginBottom="2dp" />

            <EditText
                android:id="@+id/et_sys3x3_d2"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:hint="d₂"
                android:inputType="numberDecimal|numberSigned"
                android:layout_marginBottom="8dp" />

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="a₃x + b₃y + c₃z = d₃"
                android:textSize="12sp"
                android:layout_marginBottom="2dp" />

            <EditText
                android:id="@+id/et_sys3x3_a3"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:hint="a₃"
                android:inputType="numberDecimal|numberSigned"
                android:layout_marginBottom="2dp" />

            <EditText
                android:id="@+id/et_sys3x3_b3"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:hint="b₃"
                android:inputType="numberDecimal|numberSigned"
                android:layout_marginBottom="2dp" />

            <EditText
                android:id="@+id/et_sys3x3_c3"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:hint="c₃"
                android:inputType="numberDecimal|numberSigned"
                android:layout_marginBottom="2dp" />

            <EditText
                android:id="@+id/et_sys3x3_d3"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:hint="d₃"
                android:inputType="numberDecimal|numberSigned"
                android:layout_marginBottom="8dp" />

            <Button
                android:id="@+id/btn_solve_sys_3x3"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Giải"
                android:backgroundTint="@color/teal_700" />

        </LinearLayout>

        <TextView
            android:id="@+id/tv_result"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text=""
            android:textSize="16sp"
            android:textColor="@color/black"
            android:padding="8dp"
            android:layout_marginTop="16dp"
            android:visibility="gone"
            android:background="@android:color/darker_gray" />

        <TextView
            android:id="@+id/tv_error"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text=""
            android:textSize="14sp"
            android:textColor="@color/red"
            android:padding="8dp"
            android:layout_marginTop="8dp"
            android:visibility="gone" />

        <Button
            android:id="@+id/btn_clear"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Xóa"
            android:layout_marginTop="16dp"
            android:backgroundTint="@color/teal_700" />

    </LinearLayout>

</ScrollView>